# Backend Environment Variables
# Currently no environment variables are required for basic operation

# Future configurations (uncomment and configure as needed):

# Database Configuration
# DATABASE_URL=postgresql://user:password@localhost:5432/aviation_db

# External API Keys
# AVIATION_API_KEY=your_api_key_here
# WEATHER_API_KEY=your_weather_api_key

# ML Model Configuration
# MODEL_PATH=./ml_model/trained_model.pkl
# MODEL_VERSION=1.0.0

# Server Configuration
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false

# CORS Origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
